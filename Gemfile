source "https://rubygems.org"

# fastlane for App Store screenshot framing (frameit) and, later, snapshot/deliver.
# Run it as `bundle exec fastlane ...` so it uses this pinned, project-local
# gem set rather than the half-broken Homebrew wrapper.
gem "fastlane"

# Ruby 4.0 removed these from the default gem set, but fastlane and its
# dependencies (aws-sdk-core, etc.) still expect them — declare them explicitly.
gem "logger"
gem "ostruct"
gem "mutex_m"
gem "benchmark"
gem "bigdecimal"
